---
import Layout from "../layouts/Layout.astro";
import Landing from "../components/Landing.astro";
import TitleXL from "../components/basic/TitleXL.astro";

import {
  Mechanical,
  Electronic,
  Suppliers,
} from "../components/pages/supplies";
import SuppliesImg from "../assets/img/supplies-01.jpeg";
---

<Layout
  title="Suministros Industriales para Petróleo y Gas en Colombia | Dilago Ingeniería SAS"
  description="Suministros industriales para el sector energético en Colombia: válvulas, bridas, tubería en acero al carbono e inoxidable, instrumentación electrónica y accesorios para proyectos de integridad de activos."
>
  <Landing img={SuppliesImg}>
    <TitleXL>Suministros industriales para el sector energético en Colombia.</TitleXL>
  </Landing>
  <section id="content">
    <div class="content-wrap py-0">
      <Mechanical />
      <Electronic />
      <Suppliers />
    </div>
  </section>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/basic/PageHero.astro";

import HistoryImg from "../assets/img/historia.jpg";
import MisionVision from "../components/pages/about/MisionVision.astro";
import Politicas from "../components/pages/about/Politicas.astro";
---

<Layout
  title="Nuestra Historia y Misión | Dilago Ingeniería SAS"
  description="Conoce la historia, misión, visión y políticas de calidad de Dilago Ingeniería SAS, empresa colombiana especializada en integridad de activos industriales."
>
  <PageHero
    img={HistoryImg}
    title="Nuestra historia, misión y políticas."
    label="Sobre Nosotros"
  />

  <MisionVision />
  <Politicas />
</Layout>

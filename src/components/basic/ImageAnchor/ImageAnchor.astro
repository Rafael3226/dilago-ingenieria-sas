---
import { Image } from "astro:assets";
import "./image-anchor.css";

const { img, alt, href, text } = Astro.props;
---

<a href={href}>
  <div class="a-image pos-relative">
    <Image src={img} alt={alt} style={{ width: "100%", height: "240px", objectFit: "cover" }} />
    <div class="image-overlay">
      <span class="image-overlay-text">{text}</span>
    </div>
  </div>
</a>

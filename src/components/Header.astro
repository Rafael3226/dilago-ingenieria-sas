---
import { Image } from "astro:assets";
import LogoColored from "../assets/img/logo-transparent.png";
import LogoWhite from "../assets/img/logo-dark.png";
---

<header id="header" class="transparent-header dark">
  <div id="header-wrap">
    <div class="container">
      <div class="header-row">
        <div id="logo">
          <a href="/">
            <!-- Logo blanco: visible cuando el navbar es transparente (sobre el hero) -->
            <Image
              class="logo-white-version"
              src={LogoWhite}
              alt="Dilago Logo"
              style={{ width: "auto", height: "70px" }}
            />
            <!-- Logo de color: visible cuando el navbar tiene fondo blanco (scroll) -->
            <Image
              class="logo-colored-version"
              src={LogoColored}
              alt="Dilago Logo"
              style={{ width: "auto", height: "70px" }}
            />
          </a>
        </div>
        <div class="primary-menu-trigger">
          <button class="cnvs-hamburger" type="button" title="Open Mobile Menu">
            <span class="cnvs-hamburger-box"
              ><span class="cnvs-hamburger-inner"></span></span
            >
          </button>
        </div>

        <nav class="primary-menu">
          <ul class="one-page-menu menu-container">
            <li class="menu-item">
              <a href="/#section-home" class="menu-link">
                <div>Inicio</div>
              </a>
            </li>
            <li class="menu-item">
              <a href="/#section-bussines" class="menu-link"
                ><div>Lineas de negocio</div></a
              >
            </li>
            <li class="menu-item">
              <a href="/#section-history" class="menu-link"
                ><div>Historia</div></a
              >
            </li>
            <li class="menu-item">
              <a href="/#section-experience" class="menu-link"
                ><div>Experiencia</div></a
              >
            </li>
            <li class="menu-item">
              <a href="/#section-clients" class="menu-link"
                ><div>Clientes</div></a
              >
            </li>
            <li class="menu-item">
              <a href="/#section-contact" class="menu-link"
                ><div>Contacto</div></a
              >
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </div>
</header>

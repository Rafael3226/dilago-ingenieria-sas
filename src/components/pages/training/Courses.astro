---
import { Image } from "astro:assets";
import MisionImg from "../../../assets/img/cap.jpg";
import { training as brochure } from "../../../constants/brochures.js";

const courses = [
  {
    key: "Capacitación y calificación en ensayos no destructivos",
    value: "Inspección visual Nivel II, Ultrasonido medición de espesores, Líquidos penetrantes Nivel II, Partículas Magnéticas nivel II. Ente calificador: Nivel III ASNT.",
  },
  {
    key: "Profundización en soldadura",
    value: "Ente calificador: ACOSEND (Asociación Colombiana de Soldadura y Ensayos No Destructivos).",
  },
  {
    key: "Programa de capacitación y calificación de interventores para inspección de recubrimientos industriales",
    value: "Ente calificador: ASCOR (Asociación Colombiana de Corrosión y Proyección).",
  },
];
---

<section id="section-courses" class="ds-inner-section">
  <div class="ds-inner-wrap">
    <h2>Capacitaciones</h2>
    <div class="ds-service-grid">
      <div class="ds-service-text">
        <p class="ds-inner-p">Contamos con más de 30 programas ajustados a las necesidades del mercado actual en la industria energética y metalmecánica del país. DILAGO INGENIERÍA SAS cuenta con bases de datos de más de 500 profesionales especialistas con la capacidad de diseñar programas de capacitaciones in-company que se adapten a las necesidades específicas del cliente.</p>

        <p class="ds-inner-h4" style="margin-top: 2rem;">Capacitaciones y Calificaciones Más Frecuentes</p>
        <div class="ds-object-list">
          {courses.map((c) => (
            <div class="ds-object-item">
              <div class="ds-object-key">{c.key}</div>
              <div class="ds-object-value">{c.value}</div>
            </div>
          ))}
        </div>

        <div style="margin-top: 2rem;">
          <a href={brochure.href} download={brochure.name} class="ds-btn ds-btn-primary">
            {brochure.title}
          </a>
        </div>
      </div>

      <div class="ds-service-visual">
        <Image
          src={MisionImg}
          alt="Capacitaciones técnicas en protección catódica, NDT y soldadura"
          style={{ width: "100%", borderRadius: "0.5rem", display: "block" }}
        />
      </div>
    </div>
  </div>
</section>

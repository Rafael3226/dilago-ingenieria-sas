---
import ImageZoom from "../../basic/ImageZoom.astro";
import TextList from "../../basic/TextList.astro";
import Title from "../../basic/Title.astro";
import Section from "../../basic/Section.astro";
import Separator from "../../basic/Separator.astro";

import CathodicImg from "../../../assets/img/services/pcm.png";

const contentData = {
  id: "section-services-cathodic-protection",
  title: "Sistemas de protección catódica",
  subTitle: "Diseño de SPC",
  description: [
    "Diseño e inspección de sistemas de protección catódica a líneas, tanques, recipientes y estructuras metálicas que se encuentren sometidas a fenómenos de corrosión.",
    "Nuestros diseños están avalados por un profesional NACE CP4 según la necesidad del cliente.",
  ],
  image: CathodicImg,
  imageAlt: "Imagen de protección catódica",
  evaluationHeader:
    "Evaluación, Diagnóstico, mantenimiento, recalibración de sistemas de protección catódica.",
  evaluationList: [
    "Estudios ECDA (External Corrosion Direct Assessment).",
    'Estudios de potenciales a intervalos cortos "ON-OFF" CIS (Close Intervalo Survey).',
    "Diagnóstico y reparación de rectificadores.",
    "Análisis de aislamiento eléctrico de tuberías.",
    "Detección y mitigación de interferencias.",
    "Marcaciones con GPS submétrico.",
    "Estudio de suelos.",
    "Estudios Geoeléctricos.",
    "Mantenimiento de estaciones de monitoreo.",
    "Limpieza de estructuras mediante chorro a presión.",
  ],
  inspectionHeader: "Inspección en sistemas de protección catódica.",
  inspectionList: [
    "PCM (Pipeline Current Mapper).",
    "DCVG (Direct Current Voltage Gradient).",
    "Continuidad del revestimiento.",
    "Pruebas de adherencia.",
    "Espesores de placa metálica y recubrimiento.",
    "Espesores de película seca y húmeda.",
  ],
};
---

<Section id={contentData.id} className="py-4">
  <Title slot="title">{contentData.title}</Title>
  <div slot="left">
    <div class="p-t-20">
      <h4 class="txt5 m-b-10">{contentData.subTitle}</h4>
      <TextList items={contentData.description} />
    </div>
    <div class="p-t-20">
      <h4 class="txt5 m-b-10">{contentData.evaluationHeader}</h4>
      <TextList items={contentData.evaluationList} />
    </div>
  </div>

  <div slot="right">
    <div class="hov-img-zoom bo-rad-10 m-b-30">
      <ImageZoom src={contentData.image} alt={contentData.imageAlt} />
    </div>
    <h4 class="txt5 m-b-10">{contentData.inspectionHeader}</h4>
    <TextList items={contentData.inspectionList} />
  </div>
</Section>

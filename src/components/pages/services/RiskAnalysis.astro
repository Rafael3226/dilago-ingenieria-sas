---
import { Image } from "astro:assets";
import VisionImg from "../../../assets/img/risk.jpg";
---

<section id="section-services-risk-analysis" class="ds-inner-section ds-alt">
  <div class="ds-inner-wrap">
    <h2>Análisis de Riesgos Cuantitativos QRA y de Consecuencias PHAST</h2>
    <div class="ds-service-grid ds-reverse">
      <div class="ds-service-text">
        <p class="ds-inner-p">(QRA) por sus siglas en inglés Quantified Risk Assessment es una metodología cuantitativa que analiza de forma trazable los riesgos y consecuencias que pueden surgir debido a incidentes en los sistemas — de carácter poblacional, ambiental o estructural.</p>
        <p class="ds-inner-h4">Herramientas Digitales</p>
        <ul class="ds-inner-list">
          <li>Software PHAST v 7.11 de GL DNV para el análisis de consecuencias.</li>
          <li>Software SAFETI (PHAST RISK) v 6.7 de GL DNV para el análisis probabilístico, análisis de consecuencias, estimación de riesgos individual y social (curvas FN).</li>
        </ul>
      </div>

      <div class="ds-service-visual">
        <Image
          src={VisionImg}
          alt="Análisis cuantitativo de riesgos QRA y PHAST para instalaciones industriales"
          style={{ width: "100%", borderRadius: "0.5rem", display: "block" }}
        />
      </div>
    </div>
  </div>
</section>

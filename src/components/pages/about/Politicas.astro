---
import { Image } from "astro:assets";
import PoliticasImg from "../../../assets/img/historia.jpg";

const politicas = [
  "Política de calidad",
  "Política de seguridad vial",
  "Política HSE",
  "Política de no alcohol, drogas y tabaquismo",
  "Política de prevención de acoso laboral",
  "Política anticorrupción",
  "Política de responsabilidad social",
  "Política de contratación de personal",
  "Política de desconexión laboral",
];
---

<section id="section-politicas" class="ds-inner-section ds-alt">
  <div class="ds-inner-wrap">
    <h2>Políticas Corporativas</h2>
    <div class="ds-service-grid">
      <div class="ds-service-text">
        <p class="ds-inner-h4">Marco normativo interno</p>
        <p class="ds-inner-p">
          Operamos bajo un sistema integral de gestión que define nuestros compromisos con la calidad, la seguridad, el medio ambiente y el bienestar de nuestros colaboradores y aliados.
        </p>
        <ul class="ds-object-list">
          {politicas.map((title) => (
            <li class="ds-object-item">
              <div class="ds-object-key">{title}</div>
            </li>
          ))}
        </ul>
      </div>
      <div class="ds-service-visual">
        <Image
          src={PoliticasImg}
          alt="Equipo de Dilago Ingeniería en campo"
          style={{ width: "100%", borderRadius: "0.5rem", display: "block" }}
        />
        <p class="ds-img-caption">Compromiso permanente con la integridad operacional y la sostenibilidad.</p>
      </div>
    </div>
  </div>
</section>

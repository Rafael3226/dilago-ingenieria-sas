---
import ImageZoom from "../../basic/ImageZoom.astro";

import Title from "../../basic/Title.astro";
import Section from "../../basic/Section.astro";

// Image from user slides (cropped)
import PlaceholderImg from "../../../assets/img/cropped-valve-sensors.png";

const contentData = {
  id: "section-valve-sensors",
  title: "Sensores de posicionamiento para válvulas manuales",
  description: [
    "Aloxy presenta a través de DILAGO INGENIERIA SAS una solución de sensores IoT que detecta y registra la posición de las válvulas (abierta, cerrada o en posiciones intermedias) mediante señales precisas en tiempo real.",
  ],
  image: PlaceholderImg,
  imageAlt: "Sensores de posicionamiento Aloxy",
  advantagesHeader: "VENTAJAS",
  advantagesList: [
    "Disminución en tiempos de desplazamiento, reduciendo los tiempos de ejecución.",
    "Verificación en tiempo real de las condiciones del Sistema de Aislamiento Seguro.",
    "Disponibilidad de acceso remoto de la información a través de Dashboard en tiempo real.",
    "Solo se requiere una configuración inicial.",
  ],
  footer: "Fig 1 y 2: Piloto desarrollado para CENIT, caso de éxito.",
};
---

<Section id={contentData.id}>
  <Title slot="title">{contentData.title}</Title>

  <div slot="left">
    {
      contentData.description.map((text) => (
        <p
          class="text-justify m-b-10"
          style="font-size:1.2rem; line-height:1.3;"
        >
          {text}
        </p>
      ))
    }
    <h4 class="p-t-15 m-b-10">{contentData.advantagesHeader}</h4>
    <ul style="list-style-type: disc; padding-left: 20px;">
      {
        contentData.advantagesList.map((text) => (
          <li class="m-b-5">
            <p
              class="text-justify"
              style="font-size:1.2rem; line-height:1.3; margin:0; margin-bottom: 5px;"
            >
              {text}
            </p>
          </li>
        ))
      }
    </ul>
  </div>

  <div slot="right">
    <ImageZoom src={contentData.image} alt={contentData.imageAlt} />
    <p class="text-center text-muted mt-2">
      <small>{contentData.footer}</small>
    </p>
  </div>
</Section>

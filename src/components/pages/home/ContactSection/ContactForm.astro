<form id="contact-form" class="ds-contact-form" method="POST">
  <div class="ds-form-row">
    <div class="ds-form-group">
      <label for="contact-form-name">Nombre Completo</label>
      <input
        type="text"
        id="contact-form-name"
        name="name"
        placeholder="Su nombre..."
        required
      />
    </div>
    <div class="ds-form-group">
      <label for="contact-form-email">Correo Electrónico</label>
      <input
        type="email"
        id="contact-form-email"
        name="email"
        placeholder="email@empresa.com"
        required
      />
    </div>
  </div>

  <div class="ds-form-group">
    <label for="contact-form-phone">Teléfono</label>
    <input
      type="tel"
      id="contact-form-phone"
      name="phone"
      placeholder="+57 300 000 0000"
      minlength="10"
      required
    />
  </div>

  <div class="ds-form-group">
    <label for="contact-form-message">Mensaje</label>
    <textarea
      id="contact-form-message"
      name="message"
      rows="4"
      placeholder="Escriba aquí los detalles de su proyecto..."
      required
    ></textarea>
  </div>

  <button id="contact-form-button" type="submit" class="ds-contact-submit">
    Enviar Mensaje
  </button>
</form>

<script
  type="text/javascript"
  src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"
></script>
<script is:inline src="/js/contact-form.js"></script>

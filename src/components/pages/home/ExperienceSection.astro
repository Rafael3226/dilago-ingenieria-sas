---
import { Image } from "astro:assets";
import TgiImg from "../../../assets/img/experience/tgi.jpg";
import ValvesImg from "../../../assets/img/experience/valves.jpg";

const items = [
  {
    icon: "analytics",
    title: "Inspección de rotores",
    text: "Inspección mediante líquidos penetrantes fluorescentes y ultrasonido en compresores industriales.",
  },
  {
    icon: "supervised_user_circle",
    title: "Supervisión TGI",
    text: "Cambio de recubrimiento de tubería TGI de 20'' PK14+400 de la UF4 con estándares internacionales.",
  },
  {
    icon: "shield",
    title: "Protección Catódica",
    text: "Diseño de sistema de protección catódica para tuberías de 12'' y 10'' en infraestructura petrolera.",
  },
  {
    icon: "verified",
    title: "Suministro de Válvulas",
    text: "Provisión de válvulas y accesorios certificados para la industria energética de alta presión.",
  },
];
---

<section id="section-experience" class="ds-experience">
  <div class="ds-experience-inner">
    <div class="ds-experience-layout">
      <!-- Sticky sidebar -->
      <div class="ds-experience-sidebar ds-reveal">
        <span class="ds-label-secondary">Portafolio</span>
        <h2>Nuestra Experiencia</h2>
        <p>
          Dilago Ingeniería ha participado activamente en proyectos de
          envergadura nacional, demostrando capacidad técnica en sectores
          críticos de la industria energética colombiana.
        </p>
        <Image
          src={TgiImg}
          alt="Proyecto TGI tubería Dilago Ingeniería"
        />
      </div>

      <!-- Experience items grid -->
      <div class="ds-experience-items ds-reveal" data-delay="100">
        <div class="ds-experience-grid">
          {items.map((item) => (
            <div class="ds-experience-item">
              <span class="ds-experience-icon material-symbols-outlined">{item.icon}</span>
              <h4>{item.title}</h4>
              <p>{item.text}</p>
            </div>
          ))}

          <!-- Wide image at bottom -->
          <div class="ds-experience-item ds-experience-wide-img">
            <Image
              src={ValvesImg}
              alt="Suministro de válvulas y accesorios para la industria energética"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

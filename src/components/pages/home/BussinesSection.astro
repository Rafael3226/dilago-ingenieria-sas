---
import { Image } from "astro:assets";
import SuppliesImg from "../../../assets/img/supplies-01.jpeg";
import ServicesImg from "../../../assets/img/services-01.jpeg";
import NewTechImg from "../../../assets/img/services-02.jpeg";

const cards = [
  {
    title: "Suministros",
    text: "Ofrecemos una variedad de suministros que incluyen materiales y accesorios mecánicos, así como instrumentación y equipo electrónico.",
    img: SuppliesImg,
    alt: "Suministros industriales mecánicos y electrónicos",
    href: "/supplies",
  },
  {
    title: "Servicios",
    text: "Ofrecemos una amplia gama de servicios que cumplen con los estándares y códigos internacionales, garantizando la calidad y seguridad de los proyectos.",
    img: ServicesImg,
    alt: "Servicios de ingeniería de integridad industrial",
    href: "/services",
  },
  {
    title: "Nuevas Tecnologías",
    text: "Monitoreo inalámbrico y remoto para revolucionar la eficiencia operativa y la respuesta crítica en tiempo real.",
    img: NewTechImg,
    alt: "Nuevas tecnologías de monitoreo remoto industrial",
    href: "/new-technologies",
  },
];
---

<section id="section-bussines" class="ds-business">
  <div class="ds-business-inner">
    <!-- Header -->
    <div class="ds-section-header ds-reveal">
      <h2>Líneas de Negocio</h2>
      <hr class="ds-divider" />
    </div>

    <!-- Cards grid -->
    <div class="ds-business-cards">
      {cards.map((card, i) => (
        <a href={card.href} class="ds-card ds-reveal" data-delay={String(i * 100)}>
          <div class="ds-card-image">
            <Image src={card.img} alt={card.alt} />
          </div>
          <div class="ds-card-body">
            <h3>{card.title}</h3>
            <p>{card.text}</p>
            <span class="ds-card-link">
              VER MÁS
              <span class="material-symbols-outlined" style="font-size:1.1rem">trending_flat</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

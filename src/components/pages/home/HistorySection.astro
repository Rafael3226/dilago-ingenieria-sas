---
import { Image } from "astro:assets";
import HistoryImg from "../../../assets/img/historia.jpg";
---

<section id="section-history" class="ds-history">
  <div class="ds-history-grid">
    <!-- Text column -->
    <div class="ds-history-text ds-reveal">
      <h2>¿Qué es Dilago Ingeniería?</h2>
      <a href="/about" class="ds-history-explore-btn">
        Conocer historia
        <span class="material-symbols-outlined" style="font-size:1.1rem">arrow_forward</span>
      </a>
      <p>
        Dilago Ingeniería es una firma de servicios de ingeniería con sede en Colombia,
        dedicada a proporcionar soluciones integrales en consultoría, supervisión y
        ejecución de proyectos industriales. Fundada en 2015 en Barrancabermeja, hemos
        crecido de la mano con la industria energética nacional expandiendo nuestro
        alcance a tres líneas de negocios: capacitaciones técnicas, suministros y servicios.
      </p>
    </div>

    <!-- Image + stats column -->
    <div class="ds-history-images ds-reveal" data-delay="100">
      <div class="ds-history-img-main">
        <Image
          src={HistoryImg}
          alt="Historia de Dilago Ingeniería en Colombia"
        />
      </div>
      <div class="ds-history-stats">
        <div class="ds-stat-dark">
          <span class="ds-stat-number">2015</span>
          <span class="ds-stat-label">Nacimiento en Barrancabermeja</span>
        </div>
        <div class="ds-stat-light">
          <span class="ds-stat-number" style="color: var(--ds-primary);">9+</span>
          <span class="ds-stat-label" style="color: var(--ds-on-surface-variant);">Años de Excelencia</span>
        </div>
      </div>
    </div>
  </div>
</section>
